{
  "name": "agents-login",
  "version": "0.1.0",
  "private": true,
  "description": "Centralized credential-login portal for the agent runners (controller + worker modes in one image).",
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "fastify": "5.8.5",
    "node-pty": "1.1.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "22.20.0",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "9.39.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9"
  }
}
